{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Keil: Build stm32f103",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/stm32f103/scripts/keil-build.ps1",
                "-Action",
                "Build"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Keil: Rebuild stm32f103",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/stm32f103/scripts/keil-build.ps1",
                "-Action",
                "Rebuild"
            ],
            "group": "build",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Keil: Clean stm32f103",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/stm32f103/scripts/keil-build.ps1",
                "-Action",
                "Clean"
            ],
            "problemMatcher": []
        },
        {
            "label": "STM32: Build + Flash stm32f103",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/stm32f103/scripts/stm32-flash.ps1"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "STM32: Flash Current stm32f103",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/stm32f103/scripts/stm32-flash.ps1",
                "-SkipBuild"
            ],
            "problemMatcher": []
        }
    ]
}
